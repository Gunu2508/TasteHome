# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Replace with a long random string (e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_here

# ── Database (Aiven MySQL) ────────────────────────────────────────────────────
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=21699
DB_USER=avnadmin
DB_PASSWORD=your_database_password
DB_NAME=defaultdb
DB_SSL=true
